# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
# Provided automatically by Railway when you add a PostgreSQL service.
# Copy the "DATABASE_URL" connection string from the Railway dashboard.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Your public Railway domain, e.g. https://plaincode-production.up.railway.app
NEXTAUTH_URL="https://your-app.up.railway.app"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32-output"

# ── Google OAuth (optional) ────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# ── Encryption key (AES-256-GCM) ──────────────────────────────────────────────
# REQUIRED in production. Must be exactly 64 hex chars (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="replace-with-openssl-rand-hex-32-output"

# ── Railway (auto-injected, do not set manually) ───────────────────────────────
# RAILWAY_PUBLIC_DOMAIN is set automatically by Railway to your public domain.
# Used as a fallback for constructing share URLs if NEXTAUTH_URL is not set.
# RAILWAY_PUBLIC_DOMAIN="your-app.up.railway.app"
